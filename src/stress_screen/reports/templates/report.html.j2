<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>stress_screen Report — {{ pack_id }}</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #1a1d23;
    --surface:     #22262e;
    --surface2:    #2a2f3a;
    --border:      #3a404d;
    --text:        #e4e7ef;
    --text-muted:  #8a90a0;
    --accent:      #4d9cff;
    --ok-bg:       #1a3a2a;
    --ok-fg:       #4dd88a;
    --nok-bg:      #3a1a1a;
    --nok-fg:      #ff5f5f;
    --elevated-bg: #3a2e1a;
    --elevated-fg: #ffb84d;
    --radius:      8px;
    --font:        'Segoe UI', system-ui, -apple-system, sans-serif;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    line-height: 1.6;
    padding: 0 0 3rem;
  }

  /* ---- top banner ---- */
  .banner {
    background: linear-gradient(135deg, #1e2540 0%, #12161f 100%);
    border-bottom: 2px solid var(--accent);
    padding: 2rem 2.5rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .banner h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent);
    flex: 1 1 100%;
  }
  .banner h1 span { color: var(--text); font-weight: 400; margin-left: 0.5rem; font-size: 1.1rem; }
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.5rem 2rem;
    flex: 1 1 auto;
  }
  .meta-item { display: flex; flex-direction: column; }
  .meta-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); }
  .meta-value { font-size: 0.95rem; font-weight: 600; }

  /* ---- layout ---- */
  .container { max-width: 1400px; margin: 0 auto; padding: 2rem 2.5rem; }
  section { margin-bottom: 2.5rem; }
  h2 {
    font-size: 1.2rem; font-weight: 700; color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem; margin-bottom: 1.25rem;
  }
  h3 {
    font-size: 1.05rem; font-weight: 600; color: var(--text);
    margin-bottom: 1rem;
  }

  /* ---- module section ---- */
  .module-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .module-section h3 { color: var(--text); margin-bottom: 1rem; font-size: 1.1rem; }
  .module-section h3 .badge {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-left: 0.5rem;
    vertical-align: middle;
  }
  .badge-ok  { background: var(--ok-bg);  color: var(--ok-fg);  border: 1px solid var(--ok-fg); }
  .badge-nok { background: var(--nok-bg); color: var(--nok-fg); border: 1px solid var(--nok-fg); }

  .chart-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(560px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }
  .chart-box {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    overflow: hidden;
  }
  .chart-box h4 {
    font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  /* ---- summary table ---- */
  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  thead th {
    background: var(--surface2);
    color: var(--text-muted);
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em;
    font-weight: 700;
    padding: 0.65rem 1rem;
    border-bottom: 2px solid var(--border);
    text-align: left;
  }
  tbody tr { border-bottom: 1px solid var(--border); }
  tbody tr:last-child { border-bottom: none; }
  tbody td { padding: 0.65rem 1rem; vertical-align: middle; }
  tbody tr:hover td { background: var(--surface2); }

  .verdict-ok  { background: var(--ok-bg);  color: var(--ok-fg);  font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; white-space: nowrap; }
  .verdict-nok { background: var(--nok-bg); color: var(--nok-fg); font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; white-space: nowrap; }

  .tag {
    display: inline-block;
    background: var(--nok-bg); color: var(--nok-fg);
    border: 1px solid var(--nok-fg);
    font-size: 0.72rem; font-weight: 600;
    padding: 0.1rem 0.45rem; border-radius: 3px; margin: 1px;
  }

  /* ---- cell detail card ---- */
  .cell-card {
    background: var(--surface2);
    border: 1px solid var(--nok-fg);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-top: 1rem;
  }
  .cell-card h4 { color: var(--nok-fg); font-size: 0.95rem; margin-bottom: 0.6rem; }
  .methods-list {
    display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem;
  }
  .method-tag {
    font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 3px;
    font-weight: 600;
    background: #2a1a1a; color: var(--nok-fg); border: 1px solid var(--nok-fg);
  }
  .method-tag.elevated {
    background: var(--elevated-bg); color: var(--elevated-fg); border-color: var(--elevated-fg);
  }

  /* ---- method z-score table ---- */
  .method-table-wrap { overflow-x: auto; margin-top: 1.25rem; }
  .method-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .method-table thead th {
    background: var(--surface2);
    color: var(--text-muted);
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em;
    font-weight: 700;
    padding: 0.5rem 0.6rem;
    border-bottom: 2px solid var(--border);
    text-align: center;
    white-space: nowrap;
  }
  .method-table thead th:first-child { text-align: left; }
  .method-table tbody tr { border-bottom: 1px solid var(--border); }
  .method-table tbody tr:last-child { border-bottom: none; }
  .method-table tbody td { padding: 0.45rem 0.6rem; text-align: center; font-size: 0.82rem; vertical-align: middle; }
  .method-table tbody td:first-child { text-align: left; font-weight: 600; }
  .method-table tbody tr.row-high td:first-child { color: var(--nok-fg); }
  .method-table tbody tr.row-elevated td:first-child { color: var(--elevated-fg); }
  .z-high   { color: var(--nok-fg);      font-weight: 700; }
  .z-elevated { color: var(--elevated-fg); font-weight: 600; }
  .z-normal { color: var(--text-muted); }

  /* ---- ISC sub-score panel ---- */
  .isc-panel {
    margin-top: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
  }
  .isc-panel h5 {
    font-size: 0.78rem; font-weight: 700; color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }
  .isc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem 1rem;
  }
  .isc-sub {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
  }
  .isc-sub .isc-label { color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; }
  .isc-sub .isc-z { font-size: 1rem; font-weight: 700; color: var(--text); }
  .isc-sub .isc-raw { color: var(--text-muted); font-size: 0.75rem; }

  /* ---- full-width chart section ---- */
  .chart-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .chart-section h3 { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem; }

  /* ---- footer ---- */
  footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 1rem 2.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 3rem;
  }
</style>
</head>
<body>

<!-- =====================================================================
     HEADER / BANNER
     ===================================================================== -->
<header class="banner">
  <h1>stress_screen <span>Battery Pack Analysis Report</span></h1>
  <div class="meta-grid">
    <div class="meta-item">
      <span class="meta-label">Pack ID</span>
      <span class="meta-value">{{ pack_id }}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Test Date</span>
      <span class="meta-value">{{ test_date }}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Configuration</span>
      <span class="meta-value">{{ config_str }}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Overall Verdict</span>
      <span class="meta-value">
        {% if overall_verdict == "NOK" %}
          <span class="verdict-nok">NOK</span>
        {% else %}
          <span class="verdict-ok">OK</span>
        {% endif %}
      </span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Report Generated</span>
      <span class="meta-value">{{ report_date }}</span>
    </div>
  </div>
</header>

<div class="container">

  <!-- ==================================================================
       MODULE SUMMARY TABLE
       ================================================================== -->
  <section>
    <h2>Module Summary</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Module</th>
            <th>Verdict</th>
            <th>Flagged Cells</th>
            <th>Methods Fired</th>
          </tr>
        </thead>
        <tbody>
          {% for row in summary_table_rows %}
          <tr>
            <td><strong>M{{ row.module_id }}</strong></td>
            <td>
              {% if row.verdict == "NOK" %}
                <span class="verdict-nok">NOK</span>
              {% else %}
                <span class="verdict-ok">OK</span>
              {% endif %}
            </td>
            <td>
              {% for cell_label in row.flagged_cell_labels %}
                <span class="tag">{{ cell_label }}</span>
              {% else %}
                <span style="color: var(--text-muted);">—</span>
              {% endfor %}
            </td>
            <td>
              {% if row.methods_fired %}
                {{ row.methods_fired }}
              {% else %}
                <span style="color: var(--text-muted);">—</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ==================================================================
       PACK OVERVIEW CHART
       ================================================================== -->
  <section>
    <h2>Pack Overview</h2>
    <div class="chart-section">
      <h3>Composite Z-Score Heatmap</h3>
      {{ charts.pack_heatmap | safe }}
    </div>
  </section>

  <!-- ==================================================================
       PHASE TIMELINE
       ================================================================== -->
  <section>
    <h2>Phase Timeline</h2>
    <div class="chart-section">
      <h3>Charge / Discharge / Rest</h3>
      {{ charts.phase_timeline | safe }}
    </div>
  </section>

  <!-- ==================================================================
       PER-MODULE DETAIL
       ================================================================== -->
  <section>
    <h2>Per-Module Detail</h2>

    {% for mod in module_details %}
    <div class="module-section">
      <h3>
        Module M{{ mod.module_id }}
        {% if mod.verdict == "NOK" %}
          <span class="badge badge-nok">NOK</span>
        {% else %}
          <span class="badge badge-ok">OK</span>
        {% endif %}
      </h3>

      <div class="chart-grid">
        <div class="chart-box">
          <h4>OCV Fit Overlay (Rest Phase)</h4>
          {{ mod.ocv_chart | safe }}
        </div>
        <div class="chart-box">
          <h4>dV/dQ (Charge Phase)</h4>
          {{ mod.dvdq_chart | safe }}
        </div>
      </div>

      {% if mod.all_cells %}
      <div class="method-table-wrap">
        <table class="method-table">
          <thead>
            <tr>
              <th>Cell</th>
              <th>Composite Z</th>
              {% for mname in mod.method_names %}
              <th>{{ mname | replace("_", " ") }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for cell in mod.all_cells %}
            <tr class="{% if cell.verdict == 'HIGH' %}row-high{% elif cell.verdict == 'ELEVATED' %}row-elevated{% endif %}">
              <td>{{ cell.label }}</td>
              <td class="{% if cell.composite_z >= 2.0 %}z-high{% elif cell.composite_z >= 1.0 %}z-elevated{% else %}z-normal{% endif %}">
                {{ "%.2f" | format(cell.composite_z) }}
              </td>
              {% for mr in cell.method_rows %}
              <td class="z-{{ mr.verdict | lower }}">{{ mr.z_str }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if mod.flagged_cells %}
        {% for cell in mod.flagged_cells %}
        <div class="cell-card">
          <h4>Flagged Cell: {{ cell.label }} — z={{ "%.2f"|format(cell.composite_z) }}</h4>
          <div class="methods-list">
            {% for mr in cell.method_results %}
              {% if mr.verdict == "HIGH" %}
                <span class="method-tag">{{ mr.method_name }} (HIGH, z={{ "%.2f"|format(mr.z_score) }})</span>
              {% elif mr.verdict == "ELEVATED" %}
                <span class="method-tag elevated">{{ mr.method_name }} (ELEVATED, z={{ "%.2f"|format(mr.z_score) }})</span>
              {% endif %}
            {% endfor %}
          </div>

          {% if cell.isc_detail %}
          <div class="isc-panel">
            <h5>ISC Sub-Scores</h5>
            <div class="isc-grid">
              <div class="isc-sub">
                <div class="isc-label">S1 — Excess self-discharge</div>
                <div class="isc-z">z = {{ cell.isc_detail.s1_z }}</div>
                <div class="isc-raw">excess k = {{ cell.isc_detail.s1_excess_k }}</div>
              </div>
              <div class="isc-sub">
                <div class="isc-label">S2 — Thermal slope during rest</div>
                <div class="isc-z">z = {{ cell.isc_detail.s2_z }}</div>
                <div class="isc-raw">dT/dt = {{ cell.isc_detail.s2_slope }} °C/h</div>
              </div>
              <div class="isc-sub">
                <div class="isc-label">S3 — dV/dQ area deficit</div>
                <div class="isc-z">z = {{ cell.isc_detail.s3_z }}</div>
                <div class="isc-raw">area = {{ cell.isc_detail.s3_area }}</div>
              </div>
            </div>
          </div>
          {% endif %}

          {{ cell.detail_chart | safe }}
        </div>
        {% endfor %}
      {% endif %}

    </div>
    {% endfor %}

  </section>

</div><!-- /.container -->

<!-- =====================================================================
     FOOTER
     ===================================================================== -->
<footer>
  Generated by stress_screen v{{ version }}
</footer>

</body>
</html>
